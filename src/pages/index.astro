	html.dark .social-links svg { opacity: 0.9; }

    /* Keep desktop positioning as it was - only adjust mobile/small screens */
    .wave-bubble-container #section-5 .bio-content { 
        transform: translateY(-4.5vh); /* Revert to original desktop positioning */
    }
    
    @media (max-width: 768px) {
        /* Move profile section higher on mobile for better bubble fit - OVERRIDE mobile bio-content transform */
        .wave-bubble-container #section-5 .bio-content { 
            transform: translateY(-4vh) !important; /* Keep mobile adjustment */
        }
    }
    
    @media (max-width: 480px) {
        /* Fine-tune profile section positioning on very small screens - OVERRIDE all other transforms */
        .wave-bubble-container #section-5 .bio-content { 
            transform: translateY(-5vh) !important; /* Keep small screen adjustment */
        }
    }
</style>

<script is:inline>
    // Premium scroll experience with efficient coordination
    /** @type {HTMLDivElement|null} */
    let bubbleEl = null;
    let activeIndex = 1;
    const totalSections = 6;
    const MIN_INDEX = 1;
    const MAX_INDEX = totalSections;
    const COOLDOWN_MS = 400; // Reduced for more responsive touch
    const WHEEL_MIN_DELTA = 20; // ignore tiny noise
    let lastNavAt = 0;
    let touchStartY = 0;
    let touchLastY = 0;
    
    // Premium scroll coordination - prevent conflicts
    let isProgrammaticScroll = false;
    let scrollEndTimer = null;

    /** @param {number} index */
    function setActive(index) {
        const clamped = Math.max(MIN_INDEX, Math.min(MAX_INDEX, index));
        activeIndex = clamped;
        bubbleEl && bubbleEl.setAttribute('data-active', String(activeIndex));
        
        // Premium smooth scroll with enhanced coordination
        isProgrammaticScroll = true;
        const top = (activeIndex - 1) * window.innerHeight;
        
        // Use requestAnimationFrame for smoother animation
        requestAnimationFrame(() => {
            window.scrollTo({ 
                top, 
                behavior: 'smooth'
            });
        });
        
        // Reset flag after scroll completes - shorter timeout for better responsiveness
        setTimeout(() => {
            isProgrammaticScroll = false;
        }, 30);
    }

    function canNav() { return Date.now() - lastNavAt > COOLDOWN_MS; }
    function goNext() { if (canNav()) { lastNavAt = Date.now(); setActive(activeIndex + 1); } }
    function goPrev() { if (canNav()) { lastNavAt = Date.now(); setActive(activeIndex - 1); } }

    /** @param {WheelEvent} e */
    function onWheel(e) {
        e.preventDefault();
        if (!canNav() || isProgrammaticScroll) return;
        if (Math.abs(e.deltaY) < WHEEL_MIN_DELTA) return;
        if (e.deltaY > 0) goNext(); else goPrev();
    }

    /** @param {TouchEvent} e */
    function onTouchStart(e) {
        if (isProgrammaticScroll) return;
        touchStartY = e.touches[0].clientY;
        touchLastY = touchStartY;
    }

    /** @param {TouchEvent} e */
    function onTouchMove(e) {
        if (isProgrammaticScroll) return;
        touchLastY = e.touches[0].clientY;
    }

    /** @param {TouchEvent} e */
    function onTouchEnd(e) {
        if (isProgrammaticScroll) return;
        if (!canNav()) return;
        
        const deltaY = touchStartY - touchLastY;
        const minSwipeDistance = 50; // Minimum swipe distance for navigation
        
        if (Math.abs(deltaY) > minSwipeDistance) {
            if (deltaY > 0) goNext(); else goPrev();
        }
    }

    /** @param {KeyboardEvent} e */
    function onKey(e) {
        const tgt = e.target;
        const tag = tgt && tgt.tagName ? tgt.tagName.toLowerCase() : '';
        if (tag === 'input' || tag === 'textarea' || e.isComposing) return;
        if (['ArrowDown','PageDown'].includes(e.key) || (e.key === ' ' && !e.shiftKey)) { e.preventDefault(); goNext(); }
        else if (['ArrowUp','PageUp'].includes(e.key) || (e.key === ' ' && e.shiftKey)) { e.preventDefault(); goPrev(); }
        else if (e.key === 'Home') { e.preventDefault(); lastNavAt = 0; setActive(MIN_INDEX); }
        else if (e.key === 'End') { e.preventDefault(); lastNavAt = 0; setActive(MAX_INDEX); }
    }

    /** @param {TouchEvent} e */
    function onTouchStart(e) {
        if (e.touches.length < 1) return;
        const t = e.touches.item(0); if (!t) return;
        touchStartY = t.clientY; touchLastY = touchStartY;
    }
    /** @param {TouchEvent} e */
    function onTouchMove(e) {
        if (e.touches.length < 1) return;
        const t = e.touches.item(0); if (!t) return;
        touchLastY = t.clientY;
    }
    function onTouchEnd() {
        const dy = touchStartY - touchLastY; const thr = 50;
        if (Math.abs(dy) < thr || isProgrammaticScroll) return;
        if (dy > 0) goNext(); else goPrev();
    }

    function initPaging() {
        bubbleEl = document.querySelector('.wave-bubble-container');
        setActive(activeIndex);
        
        // Remove previous listeners
        window.removeEventListener('wheel', onWheel);
        document.removeEventListener('keydown', onKey);
        window.removeEventListener('touchstart', onTouchStart);
        window.removeEventListener('touchmove', onTouchMove);
        window.removeEventListener('touchend', onTouchEnd);
        
        // Add listeners with premium coordination
        window.addEventListener('wheel', onWheel, { passive: false });
        document.addEventListener('keydown', onKey);
        window.addEventListener('touchstart', onTouchStart, { passive: true });
        window.addEventListener('touchmove', onTouchMove, { passive: true });
        window.addEventListener('touchend', onTouchEnd, { passive: true });
        
        // Keep aligned on resize
        window.addEventListener('resize', () => setActive(activeIndex), { passive: true });
        
        // Mobile-specific scroll handling
        const isMobile = window.innerWidth <= 768;
        
        window.addEventListener('scroll', () => {
            if (isProgrammaticScroll) return; // Skip during programmatic scroll
            
            if (scrollEndTimer) window.clearTimeout(scrollEndTimer);
            scrollEndTimer = window.setTimeout(() => {
                const idx = Math.round(window.scrollY / window.innerHeight) + 1;
                const newIndex = Math.max(MIN_INDEX, Math.min(MAX_INDEX, idx));
                if (newIndex !== activeIndex) {
                    activeIndex = newIndex;
                    bubbleEl && bubbleEl.setAttribute('data-active', String(activeIndex));
                }
            }, isMobile ? 150 : 100); // Slightly longer timeout on mobile only
        }, { passive: true });
    }

    initPaging();
    document.addEventListener('astro:page-load', initPaging);
</script>



